# --- Credentials / Auth ---
# Private key used to sign CLOB/API auth and orders. Keep secret.
PRIVATE_KEY=0x4103e18fbae366daf852a9574be17963adc1b3093e5b9b0da68907bf27e12874
# CLOB API key (UUID). Optional if auto-derive from PRIVATE_KEY succeeds.
POLYMARKET_CLOB_API_KEY=24a30661-1113-cfb1-e937-8a465d05f99c
# CLOB API secret paired with POLYMARKET_CLOB_API_KEY.
POLYMARKET_CLOB_SECRET=EaIMWy5IZ7tsA-OtGdQ_jKsGycqcPN6c88eKFAEBfY0=
# CLOB API passphrase paired with POLYMARKET_CLOB_API_KEY.
POLYMARKET_CLOB_PASSPHRASE=714b431a4873a7c8b88cb546d963318ef4036cd78a66cb174a70ef52e593ad8d

# --- Market Selection ---
# Gamma API host used to resolve market metadata/slugs.
GAMMA_HOST=https://gamma-api.polymarket.com
# Optional fixed market slug. Leave commented to auto-select latest BTC 5m market.
# MARKET_SLUG=btc-updown-5m-1771485300

# --- Runtime Switches ---
# If true, never sends live orders (logs decisions only).
DRY_RUN=false
# Log format: pretty (human) or json (machine). Default: pretty on terminal, json otherwise.
# LOG_FORMAT=pretty
# Master switch for live trading logic.
TRADING_ENABLED=true
# Restrict all order placement to this GMT window (timezone-aware using UTC clock).
TRADE_WINDOW_ENABLED=true
TRADE_WINDOW_START_GMT=08:30
TRADE_WINDOW_END_GMT=10:30
# Emergency kill switch. 1=true may disable/stop trading paths depending on code path.
KILL_SWITCH=0

# --- Trading Account Mode ---
# If true, signer wallet is maker; if false, use proxy/funder maker mode.
TRADING_USE_SIGNER_AS_MAKER=false
# Signature type for trading orders (0=EOA, 1/2=proxy modes depending on setup).
TRADING_SIGNATURE_TYPE=1
# Maker/funder wallet when TRADING_USE_SIGNER_AS_MAKER=false.
TRADING_FUNDER_ADDRESS=0x488C039661662a893C4f644c264DEC4264F67447
# If true, engine may post sells beyond held inventory.
ALLOW_SHORT_SELL=true

# --- Strategy / Quoting ---
# Base order size (shares/contracts) per quote side. Exchange min size applies.
ORDER_SIZE=5
# Half-spread around fair value (price points). Example 0.01 = 1 cent.
HALF_SPREAD=0.01
# Lag-arb overlay toggle (uses spot-vs-polymarket lag to bias quotes).
LAG_ARB_ENABLED=true
# Enter lag mode when absolute lag is at least this many bps.
LAG_ENTER_BPS=4
# Exit lag mode only after lag mean-reverts inside this many bps (hysteresis).
LAG_EXIT_BPS=2
# Max quote shift from lag overlay (price points).
MAX_LAG_SKEW=0.01
# Size multiplier on lag-aligned side while lag mode is active.
LAG_SIZE_MULT=1.25
# Spot signal freshness requirement for lag mode (ms).
LAG_STALE_MS=2500
# Disable lag mode this many seconds before market end.
LAG_DISABLE_BEFORE_END_SEC=35
# Enables take-profit override logic.
TAKE_PROFIT_ENABLED=true
# Take-profit threshold as fraction over entry (0.5 = +50%, 1.0 = +100%).
TAKE_PROFIT_PCT=0.25
# Inventory target (shares). 0 = neutral.
INVENTORY_TARGET=0
# Max quote shift from inventory skew logic.
INVENTORY_SKEW_MAX=0.008
# Start applying skew after this normalized inventory threshold (0-1).
INVENTORY_SKEW_START=0.30
# --- Risk Limits ---
# Max position size per outcome token (shares/contracts).
MAX_POSITION=10
# Hard cap on total inventory notional (USDC) across positions.
MAX_INVENTORY_NOTIONAL_USDC=5

# --- Execution Timing / Requote ---
# Requote only if quote moved by at least this many ticks (unless forced).
REQUOTE_TICK_THRESHOLD=2
# Force quote refresh interval in ms even if ticks are unchanged.
FORCE_REQUOTE_MS=8000

# --- Claiming (Optional) ---
# Enables auto-claimer for resolved markets (currently disabled).
AUTO_CLAIM_ENABLED=true
# Auto-claim cycle interval in ms.
AUTO_CLAIM_INTERVAL_MS=120000
# Max conditions to claim per auto-claim cycle.
AUTO_CLAIM_MAX_PER_CYCLE=2
# Polygon RPC endpoint used by claim/on-chain helper paths.
POLYGON_RPC_URL=https://polygon-rpc.com
# Optional failover list for redeem RPC (comma-separated). Tried in order with retry/rotation.
# POLYGON_RPC_URLS=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY,https://polygon-mainnet.infura.io/v3/YOUR_KEY
# Optional address to claim for (defaults to signer when omitted).
# CLAIM_ADDRESS=

# --- Legacy Auth (Reference Only) ---
# POLYMARKET_SIGNATURE_TYPE=1
# POLYMARKET_FUNDER_ADDRESS=0x488C039661662a893C4f644c264DEC4264F67447

# --- Micro Trading Overrides ---
MIN_ORDER_SIZE=5
MIN_BUY_NOTIONAL_USDC=0.1
MIN_REQUOTE_MS=3000
# Buy window from market open (seconds). Buys disabled after this window.
BUY_WINDOW_SEC=180
# Require at least this lag (bps) before opening new buys.
BUY_MIN_LAG_BPS=6
# No-chase filter: if fair jumps up by more than this in window, skip new buys.
BUY_NO_CHASE_WINDOW_MS=4000
BUY_NO_CHASE_MAX_UP_BPS=8
# Stop opening new buys if market-level net P/L (realized+unrealized) is below this (USDC). 0 disables.
MAX_LOSS_PER_MARKET_USDC=2
# Exit layering: split exit into aggressive slice + remainder.
EXIT_LAYERED_ENABLED=true
EXIT_AGGRESSIVE_PCT=0.6
EXIT_AGGRESSIVE_TICKS=2
# Price-rise exits: post slightly below best bid for faster fills, but keep at least tiny profit.
EXIT_FAST_UNDERCUT_TICKS=1
EXIT_MIN_PROFIT_TICKS=1
# Exit only after Polymarket implied move has caught up to buy-time BTC move target (plus optional buffer bps).
EXIT_CATCHUP_BUFFER_BPS=0
# If consecutive exit failures reach this, lower exit price by extra ticks to improve fill odds.
EXIT_FAILSAFE_AFTER_FAILS=3
EXIT_FAILSAFE_EXTRA_TICKS=1
# Hard venue minimum share size guard.
VENUE_MIN_ORDER_SIZE=5
# Min spacing between CLOB ledger fetches (getOpenOrders on /data/orders).
CLOB_LEDGER_MIN_INTERVAL_MS=100

NO_NEW_ORDERS_BEFORE_END=30
CANCEL_ALL_BEFORE_END=15
# Force exit mode near market end: focuses on selling inventory instead of normal quoting.
FORCE_FLATTEN_ENABLED=true
# Start forced flatten this many seconds before end (should be >= NO_NEW_ORDERS_BEFORE_END).
FORCE_FLATTEN_BEFORE_END_SEC=40
# protect_price = avoid selling below entry; guarantee_flat = prioritize getting flat.
FORCE_FLATTEN_MODE=protect_price
# If false, bot will not force-sell below average entry price.
FORCE_FLATTEN_ALLOW_LOSS=false
# If true, allow TP dust recovery via minimum-size short sell when inventory is below min order size
DUST_RECOVERY_ENABLED=true

# Periodically tries to clear small leftover positions from non-active markets
DUST_SWEEPER_ENABLED=true
DUST_SWEEPER_INTERVAL_MS=60000
DUST_SWEEPER_MAX_PER_CYCLE=1
DUST_SWEEPER_MAX_NOTIONAL_USDC=2
DUST_SWEEPER_MIN_BID=0.03
DUST_SWEEPER_ALLOW_SHORT=true

# Redeemables scanner + manual dashboard redeem
REDEEMABLES_ENABLED=true
REDEEMABLES_SCAN_INTERVAL_MS=30000
REDEEM_NOW_MAX=3
# Optional comma-separated addresses to scan for redeemables/dust visibility
# REDEEMABLES_ADDRESSES=0xYourMaker,0xYourSigner
# Optional comma-separated addresses to include in dust discovery
# DUST_SWEEPER_ADDRESSES=0xYourMaker,0xYourSigner
